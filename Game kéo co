<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trò Chơi Kéo Co Số Nguyên</title>
    <!-- FontAwesome & Font Google -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@700;900&display=swap" rel="stylesheet">
    <!-- Thư viện Pháo hoa -->
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>

    <style>
        * {
            box-sizing: border-box;
            font-family: 'Nunito', sans-serif;
        }

        body {
            background: radial-gradient(circle, #1e293b 0%, #0f172a 100%);
            margin: 0;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
            color: white;
        }

        .game-intro {
            text-align: center;
            margin-bottom: 20px;
            animation: bounceIn 1s ease;
        }

        .game-intro h2 {
            font-size: 45px;
            color: #facc15;
            text-transform: uppercase;
            text-shadow: 0 4px 10px rgba(250, 204, 21, 0.5);
            margin: 10px 0;
        }

        .battle-arena {
            background: linear-gradient(135deg, #334155, #1e293b);
            border: 4px solid #475569;
            border-radius: 30px;
            padding: 40px;
            width: 100%;
            max-width: 1000px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.5), inset 0 0 20px rgba(255,255,255,0.05);
            position: relative;
        }

        /* Trục số */
        .number-line {
            position: relative;
            width: 100%;
            height: 100px;
            background: linear-gradient(90deg, #fecaca 0%, #e2e8f0 50%, #bbf7d0 100%);
            border-radius: 50px;
            margin-bottom: 50px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 20px;
            box-shadow: inset 0 10px 20px rgba(0,0,0,0.2), 0 5px 15px rgba(0,0,0,0.3);
            border: 3px solid #cbd5e1;
        }

        .team-goal {
            font-size: 28px;
            font-weight: 900;
            z-index: 2;
            text-shadow: 2px 2px 0px #fff;
            padding: 10px 20px;
            border-radius: 20px;
        }

        .team-negative { color: #ef4444; background: rgba(255,255,255,0.7); box-shadow: 0 0 15px #ef4444; }
        .team-positive { color: #22c55e; background: rgba(255,255,255,0.7); box-shadow: 0 0 15px #22c55e; }
        .center-zero { color: #1e1b4b; background: white; border: 3px solid #1e1b4b; border-radius: 50%; width: 60px; height: 60px; display: flex; align-items: center; justify-content: center; font-size: 30px; z-index: 2;}

        /* Vạch chia độ */
        .marks-container {
            position: absolute; left: 0; top: 0; width: 100%; height: 100%;
            display: flex; justify-content: space-between; padding: 0 120px;
        }
        .mark { border-left: 3px dashed rgba(0,0,0,0.2); height: 100%; }
        .mark-center { border-left: 5px solid #1e1b4b; height: 100%; }

        /* Lá cờ */
        #game-flag {
            position: absolute;
            left: 50%;
            top: -50px;
            transform: translateX(-50%);
            transition: left 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
            font-size: 80px;
            z-index: 5;
            filter: drop-shadow(0 10px 5px rgba(0,0,0,0.3));
            animation: swing 2s infinite ease-in-out;
        }

        /* Khu vực câu hỏi */
        .question-board {
            background: #0f172a;
            border: 3px solid #38bdf8;
            border-radius: 20px;
            padding: 30px;
            text-align: center;
            box-shadow: 0 0 30px rgba(56, 189, 248, 0.2);
            position: relative;
            overflow: hidden;
        }

        #question-text {
            font-size: 40px;
            color: #facc15;
            margin-bottom: 15px;
            min-height: 60px;
            animation: pulseText 2s infinite;
        }

        #answer-text {
            font-size: 35px;
            color: #38bdf8;
            margin-bottom: 30px;
            opacity: 0;
            transform: scale(0.8);
            transition: all 0.3s ease;
            background: rgba(56, 189, 248, 0.1);
            display: inline-block;
            padding: 10px 30px;
            border-radius: 15px;
        }

        .show-answer {
            opacity: 1 !important;
            transform: scale(1) !important;
        }

        /* Nút bấm 3D */
        .btn-group {
            display: flex;
            justify-content: center;
            gap: 15px;
            flex-wrap: wrap;
        }

        .btn {
            padding: 15px 25px;
            font-size: 20px;
            font-weight: 900;
            border: none;
            border-radius: 12px;
            cursor: pointer;
            text-transform: uppercase;
            transition: all 0.1s;
            position: relative;
            top: 0;
        }

        .btn:active {
            top: 5px;
        }

        .btn-neg { background: #ef4444; color: white; box-shadow: 0 5px 0 #b91c1c; }
        .btn-pos { background: #22c55e; color: white; box-shadow: 0 5px 0 #15803d; }
        .btn-next { background: #64748b; color: white; box-shadow: 0 5px 0 #334155; }
        .btn-reveal { background: #facc15; color: #1e1b4b; box-shadow: 0 5px 0 #ca8a04; }

        /* Animations */
        @keyframes swing {
            0%, 100% { transform: translateX(-50%) rotate(-5deg); }
            50% { transform: translateX(-50%) rotate(5deg); }
        }
        @keyframes pulseText {
            0%, 100% { transform: scale(1); text-shadow: 0 0 10px rgba(250, 204, 21, 0.5); }
            50% { transform: scale(1.02); text-shadow: 0 0 20px rgba(250, 204, 21, 0.8); }
        }
        @keyframes bounceIn {
            0% { transform: translateY(-50px); opacity: 0; }
            100% { transform: translateY(0); opacity: 1; }
        }
        @keyframes flashWin {
            0%, 100% { background-color: transparent; }
            50% { background-color: rgba(255, 255, 255, 0.2); }
        }
    </style>
</head>
<body>

    <div class="game-intro">
        <i class="fa-solid fa-flag-checkered" style="font-size: 80px; margin-bottom: 10px; color: #facc15;"></i>
        <h2>Kéo Co Số Nguyên</h2>
        <p style="font-size: 24px; opacity: 0.9; margin: 0;">Trả lời đúng để kéo cờ về phe mình!</p>
    </div>

    <div class="battle-arena" id="arena">
        <div class="number-line">
            <div class="team-goal team-negative">-5 ĐỘI ÂM</div>
            <div class="center-zero">0</div>
            <div class="team-goal team-positive">ĐỘI DƯƠNG +5</div>
            
            <div class="marks-container">
                <div class="mark"></div><div class="mark"></div><div class="mark"></div><div class="mark"></div>
                <div class="mark-center"></div>
                <div class="mark"></div><div class="mark"></div><div class="mark"></div><div class="mark"></div>
            </div>

            <div id="game-flag">🚩</div>
        </div>

        <div class="question-board">
            <div id="question-text">Nhấn "Câu tiếp theo" để bắt đầu!</div>
            <div id="answer-text">Đáp án: ...</div>
            
            <div class="btn-group">
                <button class="btn btn-neg" onclick="handleAction(-1)">
                    <i class="fa-solid fa-angles-left"></i> Đội Âm Đúng
                </button>
                <button class="btn btn-next" onclick="generateQuestion()">
                    <i class="fa-solid fa-dice"></i> Câu tiếp theo
                </button>
                <button class="btn btn-reveal" onclick="showAnswer()">
                    <i class="fa-solid fa-eye"></i> Hiện đáp án
                </button>
                <button class="btn btn-pos" onclick="handleAction(1)">
                    Đội Dương Đúng <i class="fa-solid fa-angles-right"></i>
                </button>
            </div>
        </div>
    </div>

    <script>
        // === HỆ THỐNG ÂM THANH (Web Audio API) ===
        const AudioContext = window.AudioContext || window.webkitAudioContext;
        let audioCtx;

        function initAudio() {
            if (!audioCtx) audioCtx = new AudioContext();
            if (audioCtx.state === 'suspended') audioCtx.resume();
        }

        function playSound(type) {
            initAudio();
            const osc = audioCtx.createOscillator();
            const gainNode = audioCtx.createGain();
            osc.connect(gainNode);
            gainNode.connect(audioCtx.destination);

            if (type === 'moveLeft') {
                // Tiếng trầm khi kéo về số âm
                osc.type = 'triangle';
                osc.frequency.setValueAtTime(300, audioCtx.currentTime);
                osc.frequency.exponentialRampToValueAtTime(100, audioCtx.currentTime + 0.3);
                gainNode.gain.setValueAtTime(0.5, audioCtx.currentTime);
                gainNode.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.3);
                osc.start(); osc.stop(audioCtx.currentTime + 0.3);
            } else if (type === 'moveRight') {
                // Tiếng cao khi kéo về số dương
                osc.type = 'triangle';
                osc.frequency.setValueAtTime(400, audioCtx.currentTime);
                osc.frequency.exponentialRampToValueAtTime(800, audioCtx.currentTime + 0.3);
                gainNode.gain.setValueAtTime(0.5, audioCtx.currentTime);
                gainNode.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.3);
                osc.start(); osc.stop(audioCtx.currentTime + 0.3);
            } else if (type === 'pop') {
                // Tiếng pop khi hiện câu hỏi/đáp án
                osc.type = 'sine';
                osc.frequency.setValueAtTime(600, audioCtx.currentTime);
                gainNode.gain.setValueAtTime(0.3, audioCtx.currentTime);
                gainNode.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.1);
                osc.start(); osc.stop(audioCtx.currentTime + 0.1);
            } else if (type === 'win') {
                // Chuông chiến thắng
                osc.type = 'square';
                osc.frequency.setValueAtTime(440, audioCtx.currentTime); 
                osc.frequency.setValueAtTime(554.37, audioCtx.currentTime + 0.15); 
                osc.frequency.setValueAtTime(659.25, audioCtx.currentTime + 0.3); 
                osc.frequency.setValueAtTime(880, audioCtx.currentTime + 0.45); 
                gainNode.gain.setValueAtTime(0.3, audioCtx.currentTime);
                gainNode.gain.linearRampToValueAtTime(0.01, audioCtx.currentTime + 1);
                osc.start(); osc.stop(audioCtx.currentTime + 1);
            }
        }

        // === LOGIC TRÒ CHƠI ===
        let currentPosition = 0; 
        
        const questions = [
            { q: "Số đối của -18 là bao nhiêu?", a: "18" },
            { q: "Giá trị tuyệt đối |-25| bằng mấy?", a: "25" },
            { q: "So sánh: -10 và -15 (Điền dấu >, <, =)", a: "> (Lớn hơn)" },
            { q: "Sắp xếp tăng dần: 0, -5, 2, -1", a: "-5, -1, 0, 2" },
            { q: "Số nguyên âm lớn nhất là số nào?", a: "-1" },
            { q: "Khoảng cách từ điểm -4 đến 0 trên trục số là?", a: "4 đơn vị" },
            { q: "Nhiệt độ đang là -2°C, giảm thêm 3°C thì bằng bao nhiêu?", a: "-5°C" },
            { q: "(-5) đứng bên trái hay bên phải (-2) trên trục số?", a: "Bên trái" },
            { q: "Số nguyên liền trước số -10 là?", a: "-11" },
            { q: "Thực hiện phép tính: (-5) + 5 = ?", a: "0" }
        ];

        function generateQuestion() {
            playSound('pop');
            const randomIndex = Math.floor(Math.random() * questions.length);
            document.getElementById('question-text').innerText = questions[randomIndex].q;
            document.getElementById('answer-text').innerText = "Đáp án: " + questions[randomIndex].a;
            document.getElementById('answer-text').classList.remove('show-answer');
        }

        function showAnswer() {
            playSound('pop');
            document.getElementById('answer-text').classList.add('show-answer');
        }

        function handleAction(direction) {
            // Cập nhật vị trí
            currentPosition += direction;
            if(currentPosition < -5) currentPosition = -5;
            if(currentPosition > 5) currentPosition = 5;
            
            // Phát âm thanh kéo
            if(direction === -1) playSound('moveLeft');
            else playSound('moveRight');

            // Cập nhật UI Cờ (10 nấc, từ -5 đến 5 -> 0% đến 100%)
            // Trừ hao padding của thanh trục số để cờ không bị lố ra ngoài
            let percentage = ((currentPosition + 5) / 10) * 100;
            // Ép vào giữa khung chứa
            let safePercentage = 10 + (percentage * 0.8); 
            document.getElementById('game-flag').style.left = safePercentage + "%";

            // Kiểm tra Win
            if(currentPosition === -5) {
                triggerWin("ĐỘI ÂM", "#ef4444");
            } else if(currentPosition === 5) {
                triggerWin("ĐỘI DƯƠNG", "#22c55e");
            }
        }

        function triggerWin(teamName, color) {
            playSound('win');
            
            // Bắn pháo hoa
            let duration = 3 * 1000;
            let end = Date.now() + duration;

            (function frame() {
                confetti({
                    particleCount: 5,
                    angle: 60,
                    spread: 55,
                    origin: { x: 0 },
                    colors: [color, '#ffffff']
                });
                confetti({
                    particleCount: 5,
                    angle: 120,
                    spread: 55,
                    origin: { x: 1 },
                    colors: [color, '#ffffff']
                });

                if (Date.now() < end) {
                    requestAnimationFrame(frame);
                }
            }());

            // Hiệu ứng chớp nháy màn hình
            document.getElementById('arena').style.animation = "flashWin 0.5s 3";

            setTimeout(() => { 
                alert(`🎉 CHÚC MỪNG ${teamName} ĐÃ CHIẾN THẮNG TRẬN KÉO CO!`); 
                resetGame(); 
                document.getElementById('arena').style.animation = "none";
            }, 500);
        }

        function resetGame() {
            currentPosition = 0;
            document.getElementById('game-flag').style.left = "50%";
            document.getElementById('question-text').innerText = "Trận đấu mới! Nhấn 'Câu tiếp theo'.";
            document.getElementById('answer-text').classList.remove('show-answer');
        }
    </script>
</body>
</html>
